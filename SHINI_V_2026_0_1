// --- Подключение библиотек ---
#include <EncButton.h>
#include <GTimer.h>


// --- Объявление констант ---
// const тип_данных ИМЯ_КОНСТАНТЫ = значение;

const int Pusk_PIN = 5;     // Пин кнопки Пуск
const int Flap_PIN = 6;     // Пин заслонки
const int Reset_Pin = 7;    // Пин кнопки сброс
const int Thermal_Pin = 8;  // Пин кнопки Термореле
const int Motor_Pin = 12;   // Пин Мотора
const int Alarm_Pin = 11;   // Пин Аварии

// --- Объявление глобальных переменных ---
uint16_t MOTOR_TIME_SEC = 10;
uint16_t PAUSE_TIME_SEC = 5;
uint16_t Flap_TIME_MS = 3000UL;

//----Объявление переменных в коде----
//----переменные мигания----
uint16_t Thermal_alarm = 100;  // Период мигания при Thermal_alarm (мс)
uint16_t Flap_alarm = 1000;    // Период мигания при Flap_alarm (мс)
uint8_t step = 0;              // Номер шага
bool pusk_pause = false;
int8_t val_flap = 0;         // Подсчет количества срабатываний заслонки
bool flapSucceeded = false;  // Фиксируем успех в текущем цикле
//-----Флаги----
bool flag_Motor = 0;
bool flag_alarm = false;      // Флаг "Авария" для перехода в шаг 10
bool motorTimerDone = false;  // Флаг: таймер мотора сработал
bool pauseTimeDone = false;   // Флаг: таймер пауза сработал
//----Флаги для вывода текста----
bool Seril_flag_1 = false;
bool Seril_flag_2 = false;
bool Seril_flag_3 = false;
bool Seril_flag_4 = false;
bool Seril_flag_10 = false;
bool Seril_flag_10_1 = false;
bool Seril_flag_10_2 = false;
bool Reset_flag = false;
// ----Прототипы функций----
void Motor_pusk();
void Pause_pusk();
void alarmBlink();
// --- Создание объектов кнопок ---
Button Pusk(Pusk_PIN);        // Создаем объект кнопки Пуск
Button Flap(Flap_PIN);        // Создаем объект Заслонки
Button Thermal(Thermal_Pin);  // Создаем объект Термореле
Button Reset(Reset_Pin);      // Создаем обект кнопки Сброс
// ---- Создание объектов таймеров ----
GTimerCb<millis> timer_Motor(MOTOR_TIME_SEC * 1000UL, Motor_pusk, GTMode::Timeout);  // Таймер работы мотора
GTimerCb<millis> timer_Pause(PAUSE_TIME_SEC * 1000UL, Pause_pusk, GTMode::Timeout);  // Таймер промежутка Паузы
GTimerCb<millis> timer_Alarm(Thermal_alarm, alarmBlink, GTMode::Interval);           // Таймер для мигания

// === ФУНКЦИЯ setup() ===
// Выполняется один раз при включении/перезагрузке платы
void setup() {
  Serial.begin(9600);                 // Устанавливаем скорость последовательного порта 9600 бит/с
  pinMode(Motor_Pin, OUTPUT);         // Устанавливаем пин мотора в режим выхода
  pinMode(Alarm_Pin, OUTPUT);         // Устанавливаем пин сигнализации в режим выхода
  Flap.setHoldTimeout(Flap_TIME_MS);  // удержание через 3 секунду
  digitalWrite(Motor_Pin, 0);         // Изначально мотор выключен
  digitalWrite(Alarm_Pin, 0);         // Изначально индикация Alarm выключена

  // Явно останавливаем таймеры при старте
  timer_Motor.stop();  // Переводим таймер Мотора в стоп
  timer_Pause.stop();  // переводим таймер Паузы в стоп
  timer_Alarm.stop();  // переводим таймер Alarm в стоп
}

// === ФУНКЦИЯ loop() ===
// Бесконечно повторяется, пока плата включена
void loop() {  // Основная логика программы:
  //----Обязательный опрос----
  Pusk.tick();         // Опрос кнопки Пуск
  Flap.tick();         // Опрос заслонки
  Thermal.tick();      // Опрос Термореле
  Reset.tick();        // Опрос кнопки Сброс
  timer_Motor.tick();  // Проверка таймера Мотора
  timer_Pause.tick();
  timer_Alarm.tick();  // Проверка таймера мигания


  if (Thermal.press()) {  // TRUE если сработало тепловое реле
    Serial.println(F("Сработало тепловое реле. Переходим в шаг 10"));
    flag_alarm = true;  // Включаем флаг "Авария"
    digitalWrite(Motor_Pin, LOW);
    step = 10;  // Переходим в шаг "Авария"
  }
  //----------Конструкция switch-case----------------------
  switch (step) {
    case 0:

      if (Pusk.click() || pusk_pause) {
        Serial.print(F("Кнопка Пуск нажата! Запускаем мотор на  секунд"));
        Serial.println(MOTOR_TIME_SEC);
        digitalWrite(Motor_Pin, true);  // Включаем мотор
        timer_Motor.start();            // Запускаем таймер
        step = 1;
      }
      break;
    case 1:
      if (motorTimerDone) {  // Таймер timer_Motor сработал мотор отключился
        Serial.println(F("Мотор отключился. Включился таймер Пауза"));
        timer_Pause.start();
        motorTimerDone = false;
        // flag_alarm = true;

        // Seril_flag_10 = true;
        step = 2;
      }
      break;

    case 2:

      if (Flap.hold()) {
        Serial.println(F("Заслонка отработала 3 сек"));
        flapSucceeded = true;
        val_flap = 0;
      }
      if (pauseTimeDone) {
        Serial.println(F("Таймер Пауза сработал"));
        if (!flapSucceeded) {
          val_flap++;
          Serial.print(F("Заслонка не сработала "));
          Serial.println(val_flap);
        } else {
          Serial.println(F("Заслонка сработала"));
          flapSucceeded = false;
        }
        if (val_flap >= 2) {
          Seril_flag_10 = true;
          flag_alarm = true;
          step = 10;
        } else {
          step = 0;
          pusk_pause = true;
        }



        pauseTimeDone = false;
      }


      break;

    case 3:
      // Логика шага 3
      break;

    case 4:
      // Логика шага 4
      break;
    case 10:  // Шаг аварии
              // Логика мигания в зависимости от флагов и состояний
      digitalWrite(Motor_Pin, LOW);
      if (Seril_flag_10) {

        Serial.println(F("Шаг 10"));
        Seril_flag_10 = false;
        Seril_flag_10_1 = true;
        Seril_flag_10_2 = true;
        Reset_flag = true;
      }


      // В основном коде:
      if (flag_alarm) {
        if (Thermal.press()) {
          startAlarm(Thermal_alarm, F("Шаг 10 Термореле"));
        }
        if (val_flap >= 2) {
          startAlarm(Flap_alarm, F("Шаг 10 Заслонка"));
        }
      }
      
      break;
  }

  //----Обработка сброса----
  if (Reset.click()) {
    Serial.println(F("Нажат сброс"));
    timer_Alarm.stop();          // Останавливаем мигание, если флаг сброшен
    digitalWrite(Alarm_Pin, 0);  // Гасим пин
    flag_alarm = false;
    val_flap = 0;
    step = 0;
  }
  // if (Reset.click()) {
  //   if (Reset_flag) {
  //     Serial.println(F("Нажат сброс"));
  //     Reset_flag = false;
  //     timer_Alarm.stop();          // Останавливаем мигание, если флаг сброшен
  //     digitalWrite(Alarm_Pin, 0);  // Гасим пин
  //     flag_alarm = false;
  //     step = 0;
  //   }
  // }  //-------------------------
  //Serial.println(val_flap);
}
// --- Определение пользовательских функций (если есть) ---

void Motor_pusk() {
  //Serial.println(F("Таймер Мотор: мотор ВЫКЛЮЧЕН через 10 секунд!"));
  digitalWrite(Motor_Pin, LOW);  // Выключаем мотор
  motorTimerDone = true;         // Устанавливаем флаг завершения таймера
};

void Pause_pusk() {
  //Serial.println(F("Таймер Пауза сработал!"));
  pauseTimeDone = true;
};
void alarmBlink() {
  digitalWrite(Alarm_Pin, !digitalRead(Alarm_Pin));  // Инвертируем состояние пина
};
void startAlarm(uint16_t period, const __FlashStringHelper* message) {  //uint16_t period — период мигания в миллисекундах (тип uint16_t означает 16‑битное беззнаковое целое, диапазон 0–65 535 мс);    const __FlashStringHelper* message — указатель на строку во Flash‑памяти (используется с макросом F() для экономии ОЗУ).
  Serial.println(message);
  timer_Alarm.setTime(period);
  if (!timer_Alarm.running()) {  // Запускаем только если не запущен
    timer_Alarm.start();         // запускает таймер
  }
}
